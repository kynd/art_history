---
import { getCollection } from 'astro:content';
import DocLayout from '../layouts/DocLayout.astro';

export async function getStaticPaths() {
  const allDocs = await getCollection('docs');
  const docs = allDocs;

  return docs.filter((doc) => doc.id !== 'index.md').map((doc) => {
    const urlSlug = doc.slug.replace(/\/index$/, '');
    // Hierarchical path from the file system (for sidebar/breadcrumbs)
    const filePath = doc.id.replace(/\.md$/, '').replace(/\/index$/, '');
    return {
      params: { slug: urlSlug || undefined },
      props: { doc, urlSlug, filePath },
    };
  });
}

const { doc, urlSlug, filePath } = Astro.props;
const { Content } = await doc.render();

function splitTitle(title: string): { en: string; ja: string | null } {
  // Find the first Japanese/CJK character
  const jaMatch = title.match(/[぀-鿿＀-￯]/);
  if (!jaMatch || jaMatch.index === undefined) return { en: title, ja: null };
  // Split at the last space before that character (handles "3Dのデザイン", "CIE色空間", etc.)
  const lastSpace = title.lastIndexOf(' ', jaMatch.index - 1);
  if (lastSpace === -1) return { en: title, ja: null };
  const en = title.slice(0, lastSpace).trim();
  const ja = title.slice(lastSpace + 1).trim();
  return en && ja ? { en, ja } : { en: title, ja: null };
}

const { en: titleEn, ja: titleJa } = splitTitle(doc.data.title);
---

<DocLayout title={doc.data.title} slug={urlSlug} filePath={filePath}>
  <h1 class="page-title">
    <span class="title-en">{titleEn}</span>
    {titleJa && <span class="title-ja">{titleJa}</span>}
  </h1>
  <Content />
</DocLayout>
