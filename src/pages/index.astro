---
import { getCollection } from 'astro:content';
import DocLayout from '../layouts/DocLayout.astro';

const allDocs = await getCollection('docs');
const visibleDocs = allDocs;

// Find the root index document (slug === 'index')
const indexDoc = visibleDocs.find((d) => d.slug === 'index');
let Content: any = null;
let title = 'Index';

if (indexDoc) {
  const rendered = await indexDoc.render();
  Content = rendered.Content;
  title = indexDoc.data.title;
}

const SECTION_ORDER: Record<string, number> = {
  'writing-guide': 0,
  'meaning-of-art': 1,
  'first-page': 2,
  'research-and-discussions': 3,
};

// Top-level sections (depth 1, not the root index itself)
const topLevel = visibleDocs
  .filter((d) => {
    const parts = d.slug.split('/');
    // leaf pages at depth 1, OR index pages at depth 2 (section roots)
    const isTopLeaf = parts.length === 1 && d.slug !== 'index';
    const isTopSection = parts.length === 2 && parts[1] === 'index';
    return isTopLeaf || isTopSection;
  })
  .sort((a, b) => {
    const sa = a.slug.replace(/\/index$/, '');
    const sb = b.slug.replace(/\/index$/, '');
    const oa = SECTION_ORDER[sa] ?? 99;
    const ob = SECTION_ORDER[sb] ?? 99;
    return oa - ob;
  });
---

<DocLayout title={title} slug="" filePath="">
  <h1 class="page-title"><span class="title-en">{title}</span></h1>
  {Content ? (
    <Content />
  ) : (
    <>
      <h1>{title}</h1>
      <ul class="index-list">
        {topLevel.map((doc) => (
          <li>
            <a href={`${import.meta.env.BASE_URL}${doc.slug.replace(/\/index$/, '')}`}>
              {doc.data.title}
            </a>
          </li>
        ))}
      </ul>
    </>
  )}
</DocLayout>

<style>
  .index-list {
    list-style: none;
    padding: 0;
    margin-top: 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  .index-list a {
    font-size: 1.05rem;
    color: #000;
    text-decoration: none;
    border-bottom: 1px solid #eee;
    padding-bottom: 0.5rem;
    display: block;
  }
  .index-list a:hover { border-color: #000; }
</style>
