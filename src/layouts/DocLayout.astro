---
import { getCollection } from 'astro:content';
import Sidebar from '../components/Sidebar.astro';

export interface Props {
  title: string;
  slug: string;
  filePath: string;
}

const { title, slug, filePath } = Astro.props;
const isResearch = slug.startsWith('research-and-discussions') || filePath.startsWith('research-and-discussions');

const allDocs = await getCollection('docs');
const visibleDocs = allDocs;

type TreeNode = {
  label: string;
  path: string; // hierarchical path (from doc.id) for active-state detection
  url: string;  // short slug URL for link hrefs
  children: Map<string, TreeNode>;
};

// Desired top-level section order (slug → position)
const SECTION_ORDER: Record<string, number> = {
  'writing-guide': 0,
  'meaning-of-art': 1,
  'first-page': 2,
  'research-and-discussions': 3,
};

function buildTree(docs: typeof allDocs): TreeNode {
  const root: TreeNode = { label: 'root', path: '', url: '', children: new Map() };

  // Pre-build a map from hierarchical path → short slug URL
  const pathToUrl = new Map<string, string>();
  for (const doc of docs) {
    const fp = doc.id.replace(/\.md$/, '').replace(/\/index$/, '');
    pathToUrl.set(fp, doc.slug);
  }

  for (const doc of docs) {
    const fp = doc.id.replace(/\.md$/, '').replace(/\/index$/, '');
    if (fp === '' || fp === 'index') continue; // root homepage
    const parts = fp.split('/');
    let node = root;
    for (let i = 0; i < parts.length; i++) {
      const part = parts[i];
      const nodePath = parts.slice(0, i + 1).join('/');
      if (!node.children.has(part)) {
        node.children.set(part, {
          label: i === parts.length - 1 ? (doc.data.title || part) : part,
          path: nodePath,
          url: pathToUrl.get(nodePath) || nodePath,
          children: new Map(),
        });
      } else if (i === parts.length - 1) {
        const existing = node.children.get(part)!;
        existing.label = doc.data.title || existing.label;
        existing.url = doc.slug;
      }
      node = node.children.get(part)!;
    }
  }

  // Sort root-level children by SECTION_ORDER
  const sorted = [...root.children.entries()].sort(([a], [b]) => {
    const oa = SECTION_ORDER[a] ?? 99;
    const ob = SECTION_ORDER[b] ?? 99;
    return oa - ob;
  });
  root.children = new Map(sorted);

  return root;
}

const tree = buildTree(visibleDocs);

const base = import.meta.env.BASE_URL.replace(/\/$/, '');

function buildBreadcrumbs(fp: string, docs: typeof visibleDocs) {
  const parts = fp.split('/').filter(Boolean);
  const crumbs: { label: string; href: string }[] = [
    { label: 'Home', href: base || '/' },
  ];

  let cumulative = '';
  for (let i = 0; i < parts.length; i++) {
    cumulative += (i > 0 ? '/' : '') + parts[i];
    const match = docs.find((d) => {
      const dfp = d.id.replace(/\.md$/, '').replace(/\/index$/, '');
      return dfp === cumulative;
    });
    crumbs.push({
      label: match?.data.title || parts[i],
      href: match ? `${base}/${match.slug}` : `${base}/${cumulative}`,
    });
  }
  return crumbs;
}

const breadcrumbs = buildBreadcrumbs(filePath, visibleDocs);
