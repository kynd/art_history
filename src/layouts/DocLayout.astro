<!DOCTYPE html>
<html lang="en" class="notranslate" translate="no">
<head>
  <meta charset="UTF-8" />
  <meta name="google" content="notranslate" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/katex@0.16.25/dist/katex.min.css" crossorigin="anonymous" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20,400,0,0&icon_names=link" />
  <script async src="//www.instagram.com/embed.js"></script>
  <script async src="https://cpwebassets.codepen.io/assets/embed/ei.js"></script>
  <script is:inline>
    (function() {
      var f = localStorage.getItem('font-mode') || 'serif';
      document.documentElement.setAttribute('data-font', f);
      // Set sidebar state before first paint to prevent flash of wrong state
      if (localStorage.getItem('sidebar-open') === 'true') {
        document.documentElement.classList.add('sidebar-open');
      }
    })();
  </script>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Noto+Sans+JP:wght@300;400;500;600;700&family=Noto+Serif+JP:wght@400;500;600;700&family=Sora:wght@300;400;500;600;700&family=Google+Sans+Code:ital,wght@0,400;0,500;0,700;1,400&display=swap"
    rel="stylesheet"
  />
  <style is:global>
    /* ── Reset & Base ─────────────────────────────────────────────── */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #ffffff;
      --fg: #343434;
      --fg-muted: #777777;
      --border: #e8e8e8;
      --link: rgb(49, 113, 222);
      --sidebar-width: 375px;
      --header-height: 64px;
      --font-body: 'Sora', 'Noto Sans JP', sans-serif;
      --font-code: 'Google Sans Code', 'Fira Mono', monospace;
    }
    html[data-font="serif"] {
      --font-body: 'Lora', 'Noto Serif JP', serif;
    }

    html, body {
      background: var(--bg);
      color: var(--fg);
      font-family: var(--font-body);
      font-size: 18px;
      line-height: 1.7;
      min-height: 100vh;
    }

    /* ── Layout Shell ─────────────────────────────────────────────── */
    .shell {
      display: flex;
      min-height: 100vh;
    }

    /* ── Top Bar ──────────────────────────────────────────────────── */
    .topbar {
      position: fixed;
      top: 0; left: 0; right: 0;
      height: var(--header-height);
      background: transparent;
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 1rem;
      z-index: 100;
      pointer-events: none;
    }

    .topbar-controls {
      display: flex;
      align-items: center;
      background: rgba(255, 255, 255, 0.76);
      border-radius: 8px;
      backdrop-filter: blur(6px);
      -webkit-backdrop-filter: blur(6px);
      pointer-events: all;
    }
    .topbar-controls-left { padding: 0.22rem; }
    .topbar-controls-right { padding: 0.22rem 0.55rem; }

    .topbar-toggle {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 30px;
      height: 30px;
      background: none;
      border: none;
      cursor: pointer;
      color: var(--fg);
      border-radius: 5px;
      transition: background 0.15s;
      flex-shrink: 0;
    }
    .topbar-toggle:hover { background: rgba(0,0,0,0.06); }

    .topbar-font-switcher {
      display: flex;
      align-items: center;
      gap: 0.25rem;
    }
    .font-opt {
      background: none;
      border: none;
      cursor: pointer;
      padding: 0.2rem 0.1rem;
      font-size: 0.75rem;
      color: var(--fg-muted);
      letter-spacing: 0.01em;
      transition: color 0.15s;
    }
    .font-opt:hover { color: var(--fg); }
    .font-opt.active { color: var(--fg); font-weight: 600; }
    .font-sep { color: #ccc; font-size: 0.75rem; user-select: none; }

    /* ── Content breadcrumb ───────────────────────────────────────── */
    .content-breadcrumb {
      display: flex;
      flex-wrap: wrap;
      align-items: center;
      gap: 0.2rem 0.3rem;
      font-size: 0.75rem;
      color: var(--fg-muted);
      margin-bottom: 2.1rem;
    }
    .content-breadcrumb a {
      color: var(--fg-muted);
      text-decoration: none;
    }
    .content-breadcrumb a:hover { color: var(--fg); }
    .content-breadcrumb .cb-sep { color: #ccc; }

    /* ── Sidebar ──────────────────────────────────────────────────── */
    .sidebar-backdrop {
      display: none;
      position: fixed;
      inset: 0;
      background: rgba(0,0,0,0.08);
      z-index: 98;
    }

    .sidebar {
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      width: var(--sidebar-width);
      background: var(--bg);
      overflow-y: auto;
      z-index: 101;
      transform: translateX(calc(-1 * var(--sidebar-width)));
      transition: transform 0.22s ease;
      padding: 1rem 0 2rem;
    }

    .shell.sidebar-open .sidebar,
    html.sidebar-open .sidebar {
      transform: translateX(0);
      box-shadow: 4px 0 24px rgba(0,0,0,0.07);
    }

    .shell.no-transition .sidebar,
    .shell.no-transition .main-wrap {
      transition: none !important;
    }

    .shell.sidebar-open .sidebar-backdrop,
    html.sidebar-open .sidebar-backdrop {
      display: block;
    }

    /* ── Main Content ─────────────────────────────────────────────── */
    .main-wrap {
      flex: 1;
      margin-top: var(--header-height);
      margin-left: 0;
      transition: margin-left 0.22s ease;
      min-width: 0;
    }

    .shell.sidebar-open .main-wrap,
    html.sidebar-open .main-wrap {
      margin-left: var(--sidebar-width);
    }

    .main-inner {
      max-width: 860px;
      margin: 0 auto;
      padding: 2em 2.5rem 5rem;
    }

    /* ── Article Typography (is:global so it reaches markdown content) */
    .prose h1.page-title {
      font-size: 3rem;
      font-weight: 300;
      letter-spacing: -0.03em;
      line-height: 1.15;
      margin-bottom: 3rem;
    }
    .prose h1.page-title .title-en,
    .prose h1.page-title .title-ja {
      display: block;
    }
    .prose h1.page-title .title-ja {
      margin-top: 0.3em;
    }
    .prose h1 {
      font-size: 1.55rem;
      font-weight: 600;
      letter-spacing: -0.02em;
      line-height: 1.25;
      margin-top: 2.75rem;
      margin-bottom: 1.6rem;
    }
    .prose h2 {
      font-size: 1.25rem;
      font-weight: 600;
      letter-spacing: -0.02em;
      margin-top: 2.25rem;
      margin-bottom: 1.6rem;
    }
    .prose h3 {
      font-size: 1.05rem;
      font-weight: 600;
      margin-top: 1.75rem;
      margin-bottom: 1.2rem;
    }
    /* Bilingual heading pairs: pull Japanese heading close to English, generous space after */
    .prose h1 + h1,
    .prose h2 + h2,
    .prose h3 + h3 {
      margin-top: -1rem;
      margin-bottom: 1.6rem;
    }

    /* ── Anchor link icons ────────────────────────────────────────── */
    .prose h1:not(.page-title),
    .prose h2,
    .prose h3 {
      position: relative;
    }
    .anchor-copy-btn {
      position: absolute;
      left: -1.9rem;
      width: 1.9rem; /* spans the full gap to the heading's left edge — no mouse-gap */
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0;
      pointer-events: none;
      background: none;
      border: none;
      cursor: pointer;
      padding: 0;
      color: var(--fg-muted);
      transition: opacity 0.12s;
    }
    /* Center icon on the first line of each heading level.
       top = (font-size × line-height − icon-size) / 2 */
    .prose h1:not(.page-title) > .anchor-copy-btn {
      top: calc((1.55rem * 1.25 - 1rem) / 2);
    }
    .prose h2 > .anchor-copy-btn {
      top: calc((1.25rem * 1.7 - 1rem) / 2);
    }
    .prose h3 > .anchor-copy-btn {
      top: calc((1.05rem * 1.7 - 1rem) / 2);
    }
    .anchor-copy-btn .material-symbols-outlined {
      font-size: 1rem;
      line-height: 1;
      user-select: none;
    }
    .prose h1:not(.page-title):hover > .anchor-copy-btn,
    .prose h2:hover > .anchor-copy-btn,
    .prose h3:hover > .anchor-copy-btn,
    .anchor-copy-btn:hover {
      opacity: 1;
      pointer-events: auto;
    }
    /* Bilingual pairs: hide icon on the Japanese (second) heading */
    .prose h1:not(.page-title) + h1 > .anchor-copy-btn,
    .prose h2 + h2 > .anchor-copy-btn,
    .prose h3 + h3 > .anchor-copy-btn {
      display: none;
    }
    .prose p {
      margin-bottom: 2.1rem;
    }
    .prose a {
      color: var(--link);
      text-decoration: none;
    }
    .prose a:hover { opacity: 0.75; }
    .prose ul, .prose ol {
      padding-left: 1.5rem;
      margin-bottom: 2.1rem;
    }
    .prose li {
      margin-bottom: 0.6rem;
    }
    .prose li > p {
      margin-bottom: 0.35rem;
    }
    .prose li > ul, .prose li > ol {
      margin-top: 0.35rem;
      margin-bottom: 0;
    }
    .prose li:has(> ul):not(:first-child),
    .prose li:has(> ol):not(:first-child) {
      margin-top: 1.6rem;
    }
    .prose ul { list-style-type: '- '; }
    .katex-mathml {
      position: absolute;
      clip: rect(1px, 1px, 1px, 1px);
      height: 1px;
      width: 1px;
      overflow: hidden;
      padding: 0;
      border: 0;
    }
    .prose blockquote {
      border-left: 2px solid var(--border);
      padding-left: 1rem;
      color: var(--fg-muted);
      margin: 1rem 0;
    }
    .prose code {
      font-family: var(--font-code);
      font-size: 0.87em;
      background: #f5f5f5;
      padding: 0.15em 0.35em;
      border-radius: 3px;
    }
    .prose pre {
      font-family: var(--font-code);
      font-size: 0.87em;
      background: #f5f5f5;
      border-radius: 5px;
      padding: 1.25rem;
      overflow-x: auto;
      margin: 1.25rem 0;
    }
    .prose pre code {
      background: none;
      padding: 0;
    }
    .prose img {
      max-width: 100%;
      width: 100%;
      height: auto;
      display: block;
      border-radius: 4px;
      margin: 3rem auto;
    }
    .prose img[title="75"] { width: 75%; }
    .prose img[title="50"] { width: 50%; }
    .prose img[title="25"] { width: 25%; }
    /* Make image-wrapping links block so % widths are relative to content area */
    .prose a:has(> img) {
      display: block;
    }
    /* Style paragraphs immediately following an image-link as captions */
    .prose a:has(> img) + p,
    .prose img + p,
    .prose p:has(> a > img) + p,
    .prose p:has(> a > img) + p:has(> a > img) + p {
      font-size: 0.8em;
      color: var(--fg-muted);
      text-align: left;
      margin-top: -1.75rem;
      margin-bottom: 2.75rem;
      line-height: 1.5;
    }
    .prose a:has(> img) + p a,
    .prose img + p a,
    .prose p:has(> a > img) + p a,
    .prose p:has(> a > img) + p:has(> a > img) + p a {
      color: var(--fg-muted);
      text-decoration: underline;
    }
    .prose a:has(> img) + p a:hover,
    .prose img + p a:hover,
    .prose p:has(> a > img) + p a:hover,
    .prose p:has(> a > img) + p:has(> a > img) + p a:hover {
      color: var(--fg);
    }
    .prose .video-wrap {
      position: relative;
      width: 100%;
      padding-bottom: 56.25%; /* 16:9 */
      margin: 3rem 0;
    }
    .prose .video-wrap iframe {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
      border: none;
      border-radius: 4px;
    }
    .prose .codepen-wrap {
      margin: 3rem 0;
      border-radius: 4px;
      overflow: hidden;
    }
    .prose .codepen-wrap p.codepen {
      margin: 0;
      border: none !important;
    }
    .prose .codepen-wrap iframe {
      display: block;
      border-radius: 4px;
      height: 504px !important;
    }
    .prose .video-embed {
      margin: 2rem 0;
      aspect-ratio: 16 / 9;
      width: 100%;
    }
    .prose .video-embed iframe {
      width: 100%;
      height: 100%;
      display: block;
      border: none;
      border-radius: 4px;
    }
    .prose .openprocessing-wrap {
      margin: 3rem 0;
      border-radius: 4px;
      overflow: hidden;
    }
    .prose .openprocessing-wrap iframe {
      display: block;
      width: 100%;
      border-radius: 4px;
    }
    .prose .local-video-wrap {
      margin: 3rem 0;
    }
    .prose .local-video-wrap video {
      width: 100%;
      border-radius: 4px;
      display: block;
    }
    .prose .instagram-wrap {
      margin: 3rem auto;
      max-width: 540px;
    }
    .prose .bookmark-card {
      margin: 2rem 0;
      border: 1px solid var(--border);
      border-radius: 6px;
      overflow: hidden;
      transition: border-color 0.15s;
    }
    .prose .bookmark-card:hover { border-color: #bbb; }
    .prose .bookmark-link {
      display: flex;
      align-items: stretch;
      text-decoration: none;
      color: inherit;
      height: 8em;
      overflow: hidden;
    }
    .prose .bookmark-info {
      flex: 1 1 0;
      min-width: 0;
      padding: 0.85rem 1rem;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      gap: 0.3rem;
    }
    .prose .bookmark-title {
      font-size: 0.88em;
      font-weight: 500;
      color: var(--fg);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .prose .bookmark-description {
      font-size: 0.78em;
      color: var(--fg-muted);
      overflow: hidden;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      line-height: 1.5;
    }
    .prose .bookmark-url {
      font-size: 0.72em;
      color: var(--fg-muted);
      display: flex;
      align-items: center;
      gap: 5px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .prose .bookmark-url span {
      overflow: hidden;
      text-overflow: ellipsis;
    }
    .prose .bookmark-favicon {
      width: 14px !important;
      height: 14px !important;
      flex-shrink: 0;
      object-fit: contain;
      border-radius: 0;
      margin: 0;
      display: inline-block;
    }
    .prose .bookmark-image {
      width: auto !important;
      height: 100%;
      flex-shrink: 0;
      object-fit: contain;
      display: block;
      border-radius: 0;
      margin: 0;
    }
    @media (max-width: 540px) {
      .prose .bookmark-image { display: none; }
    }
    .prose .image-row {
      display: flex;
      gap: 1em;
      align-items: flex-start;
    }
    .prose .image-row figure {
      flex: 1;
      margin: 0;
    }
    .prose .image-row img {
      width: 100%;
      height: auto;
    }
    .prose hr {
      border: none;
      border-top: 1px solid var(--border);
      margin: 2rem 0;
    }
    .prose table {
      width: 100%;
      border-collapse: collapse;
      margin: 1.25rem 0;
      font-size: 0.9em;
    }
    .prose th, .prose td {
      border: 1px solid var(--border);
      padding: 0.5rem 0.75rem;
      text-align: left;
    }
    .prose th { font-weight: 600; background: #fafafa; }
    .prose figure img { margin: 0; }
    .prose figure { margin-bottom: 2rem; }
    .prose figcaption {
      font-size: 0.8em;
      color: #666;
      margin-top: 0.5rem;
      margin-bottom: 2rem;
      line-height: 1.5;
    }
    .prose figure img + figcaption,
    .prose figure img + * + figcaption {
      margin-top: -2rem;
      margin-bottom: 3rem;
    }
    .prose table.matrix-table {
      width: auto;
      font-family: var(--font-code);
      font-size: 0.85em;
    }
    .prose table.matrix-table td {
      text-align: left;
      padding: 0.3rem 0.75rem;
      min-width: 3rem;
    }
    .prose details {
      border: 1px solid var(--border);
      border-radius: 4px;
      padding: 0.5rem 0.75rem;
      margin: 0.75rem 0;
    }
    .prose summary { cursor: pointer; font-weight: 500; }

    .prose aside {
      display: flex;
      gap: 0.75rem;
      background: #f7f7f7;
      border-radius: 6px;
      padding: 0.9rem 1rem;
      margin: 1.25rem 0;
      font-size: 0.875rem;
      line-height: 1.6;
    }
    .prose aside.editor-note {
      border-left: 2px solid #ff8c00;
      background: #fffcf0;
    }
    .prose aside.editor-note .aside-icon {
      color: #ff8c00;
    }
    .prose aside .aside-icon {
      flex-shrink: 0;
      font-size: 1.1rem;
      line-height: 1.6;
    }
    .prose aside .aside-body > * + * { margin-top: 0.35rem; }
    .prose aside .aside-body p { margin: 0; }
    .prose aside .aside-body a { text-decoration: underline; }

    .ai-disclaimer {
      font-size: 0.78rem;
      color: var(--fg-muted);
      border-bottom: 1px solid var(--border);
      padding-bottom: 0.8rem;
      margin-bottom: 2.5rem;
      line-height: 1.6;
    }
    .ai-disclaimer p {
      margin-bottom: 0.5rem;
    }
    .ai-disclaimer a {
      color: var(--fg-muted);
      text-decoration: underline;
    }
    .ai-disclaimer a:hover {
      color: var(--fg);
    }

    /* ── Site Footer ─────────────────────────────────────────────── */
    .site-footer {
      display: flex;
      justify-content: space-between;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.5rem 1.5rem;
      margin-top: 4rem;
      padding-top: 1.25rem;
      border-top: 1px solid var(--border);
      font-size: 0.8rem;
      color: var(--fg-muted);
    }
    .site-footer a {
      color: var(--fg-muted);
      text-decoration: none;
    }
    .site-footer a:hover { color: var(--fg); }
    .site-footer-left, .site-footer-right {
      display: flex;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
    }

    /* ── Mobile ───────────────────────────────────────────────────── */
    @media (max-width: 768px) {
      .shell.sidebar-open .main-wrap,
      html.sidebar-open .main-wrap {
        margin-left: 0;
      }
      .main-inner {
        padding: 1.5rem 1.25rem 3rem;
      }
      .prose h1 { font-size: 1.5rem; }
    }

    /* ── Research Page Overrides ──────────────────────────────────── */
    body.is-research {
      --font-body: 'Sora', 'Noto Sans JP', sans-serif !important;
    }
    body.is-research .topbar-controls-right {
      display: none;
    }
    body.is-research .prose {
      font-size: 14px;
      line-height: 1.6;
    }
    body.is-research .prose h1.page-title {
      font-size: 1.6rem;
      margin-top: 1rem;
      margin-bottom: 1.5rem;
    }
    body.is-research .prose h1.page-title .title-ja {
      font-size: 1.1rem;
      margin-top: 0.25em;
    }
    body.is-research .prose h1:not(.page-title) {
      font-size: 1.25rem;
      margin-top: 1.8rem;
      margin-bottom: 0.8rem;
    }
    body.is-research .prose h2 {
      font-size: 1.1rem;
      margin-top: 1.5rem;
      margin-bottom: 0.8rem;
    }
    body.is-research .prose h3 {
      font-size: 1rem;
      margin-top: 1.2rem;
      margin-bottom: 0.6rem;
    }
    body.is-research .prose h1 + h1,
    body.is-research .prose h2 + h2,
    body.is-research .prose h3 + h3 {
      margin-top: -0.6rem;
      margin-bottom: 0.8rem;
    }
    body.is-research .prose p,
    body.is-research .prose ul,
    body.is-research .prose ol {
      margin-bottom: 1rem;
    }
    body.is-research .prose li {
      margin-bottom: 0.3rem;
    }
    body.is-research .prose li > p {
      margin-bottom: 0.15rem;
    }
    body.is-research .prose li > ul,
    body.is-research .prose li > ol {
      margin-top: 0.15rem;
    }
    body.is-research .prose li:has(> ul):not(:first-child),
    body.is-research .prose li:has(> ol):not(:first-child) {
      margin-top: 0.8rem;
    }
    body.is-research .prose hr {
      margin: 1.2rem 0;
    }
    body.is-research .ai-disclaimer {
      padding-bottom: 0.5rem;
      margin-bottom: 1.5rem;
    }
  </style>
</head>
<body class={isResearch ? 'is-research' : ''}>
  <header class="topbar">
    <div class="topbar-controls topbar-controls-left">
      <button class="topbar-toggle" id="sidebar-toggle" aria-label="Toggle sidebar">
        <svg width="18" height="14" viewBox="0 0 18 14" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round">
          <line x1="0" y1="1" x2="18" y2="1"/>
          <line x1="0" y1="7" x2="18" y2="7"/>
          <line x1="0" y1="13" x2="18" y2="13"/>
        </svg>
      </button>
    </div>
    <div class="topbar-controls topbar-controls-right">
      <div class="topbar-font-switcher">
        <button class="font-opt" id="font-btn-serif" style="font-family:'Lora','Noto Serif JP',serif">Serif</button>
        <span class="font-sep">|</span>
        <button class="font-opt" id="font-btn-sans" style="font-family:'Sora','Noto Sans JP',sans-serif">Sans</button>
      </div>
    </div>
  </header>

  <div class="shell" id="app-shell">
    <div class="sidebar-backdrop" id="sidebar-backdrop"></div>

    <nav class="sidebar" aria-label="Site navigation">
      <a href={base || '/'} class={`sl sidebar-home${filePath === '' ? ' current' : ''}`} style="padding-left:36px; margin-bottom:0.25rem">Art History 美術史</a>
      <Sidebar tree={tree} currentSlug={filePath} />
    </nav>

    <main class="main-wrap">
      <div class="main-inner">
        <article class="prose">
          {breadcrumbs.length > 2 && (
            <nav class="content-breadcrumb" aria-label="Breadcrumb">
              {breadcrumbs.slice(0, -1).map((crumb, i) => (
                <span style="display:contents">
                  {i > 0 && <span class="cb-sep">/</span>}
                  <a href={crumb.href}>{crumb.label}</a>
                </span>
              ))}
            </nav>
          )}
          {filePath !== '' && (
            <div class="ai-disclaimer">
              <p>
                This page is written by AI with a human editor. Learn more about the process on the <a href={base || '/'}>homepage</a>.
              </p>
              <p>
                このページはAIと人間の編集者によって執筆されています。プロセスの詳細については<a href={base || '/'}>トップページ</a>をご覧ください。
              </p>
            </div>
          )}
          <slot />
        </article>
        <footer class="site-footer">
          <div class="site-footer-left">
            <a href={base || '/'}>Art History / 美術史</a>
          </div>
          <div class="site-footer-right">
            <a href="https://creativecommons.org/licenses/by-nc-sa/4.0/" target="_blank" rel="noopener noreferrer">CC BY-NC-SA</a>
          </div>
        </footer>
      </div>
    </main>
  </div>

  <script>
    const STORAGE_KEY = 'sidebar-open';
    const shell = document.getElementById('app-shell')!;
    const toggleBtn = document.getElementById('sidebar-toggle')!;
    const backdrop = document.getElementById('sidebar-backdrop')!;

    function applyState(open: boolean) {
      shell.classList.toggle('sidebar-open', open);
      document.documentElement.classList.toggle('sidebar-open', open);
      localStorage.setItem(STORAGE_KEY, String(open));
    }

    const stored = localStorage.getItem(STORAGE_KEY);
    shell.classList.add('no-transition');
    applyState(stored === 'true');
    requestAnimationFrame(() => shell.classList.remove('no-transition'));

    toggleBtn.addEventListener('click', () => {
      applyState(!shell.classList.contains('sidebar-open'));
    });

    backdrop.addEventListener('click', () => applyState(false));

    document.addEventListener('click', (e) => {
      if (!shell.classList.contains('sidebar-open')) return;
      const sidebar = document.querySelector('.sidebar')!;
      if (!sidebar.contains(e.target as Node) && !toggleBtn.contains(e.target as Node)) {
        applyState(false);
      }
    });

    // Font switcher
    const FONT_KEY = 'font-mode';
    const btnSerif = document.getElementById('font-btn-serif')!;
    const btnSans = document.getElementById('font-btn-sans')!;
    function applyFont(mode: string) {
      document.documentElement.setAttribute('data-font', mode);
      localStorage.setItem(FONT_KEY, mode);
      btnSerif.classList.toggle('active', mode === 'serif');
      btnSans.classList.toggle('active', mode === 'sans');
    }
    applyFont(localStorage.getItem(FONT_KEY) || 'serif');
    btnSerif.addEventListener('click', () => applyFont('serif'));
    btnSans.addEventListener('click', () => applyFont('sans'));

    // Click image to open in new tab
    document.querySelectorAll<HTMLImageElement>('.prose img').forEach((img) => {
      img.style.cursor = 'zoom-in';
      img.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        window.open(img.src, '_blank', 'noopener');
      });
    });
  </script>
  <script>
    function alignCaptions() {
      document.querySelectorAll('.prose p > a > img').forEach(img => {
        const caption = img.closest('p')?.nextElementSibling;
        if (!caption || caption.tagName !== 'P' || caption.querySelector('img')) return;
        const w = img.offsetWidth;
        if (w > 0) caption.style.maxWidth = w + 'px';
      });
    }
    window.addEventListener('load', alignCaptions);
    window.addEventListener('resize', alignCaptions);
  </script>
  <script>
    (function () {
      function slugify(text: string): string {
        return text.trim()
          .toLowerCase()
          .replace(/[^\w\s-]/g, '')
          .replace(/\s+/g, '-')
          .replace(/^-+|-+$/g, '');
      }

      const seen: Record<string, number> = {};

      function uniqueId(base: string): string {
        if (!base) {
          base = 'section';
        }
        if (!seen[base]) {
          seen[base] = 1;
          return base;
        }
        seen[base]++;
        return base + '-' + seen[base];
      }

      document.querySelectorAll<HTMLElement>(
        '.prose h1:not(.page-title), .prose h2, .prose h3'
      ).forEach((heading) => {
        const id = uniqueId(slugify(heading.textContent || ''));
        heading.id = id;

        const btn = document.createElement('button');
        btn.className = 'anchor-copy-btn';
        btn.setAttribute('aria-label', 'Copy link to section');
        btn.innerHTML = '<span class="material-symbols-outlined">link</span>';

        btn.addEventListener('click', (e) => {
          e.preventDefault();
          const url = window.location.origin + window.location.pathname + '#' + id;
          navigator.clipboard.writeText(url).catch(() => {
            const ta = document.createElement('textarea');
            ta.value = url;
            document.body.appendChild(ta);
            ta.select();
            document.execCommand('copy');
            ta.remove();
          });
        });

        heading.prepend(btn);
      });

      // Bilingual pairs: hovering the Japanese (second) heading shows the English icon
      document.querySelectorAll<HTMLElement>(
        '.prose h1:not(.page-title) + h1, .prose h2 + h2, .prose h3 + h3'
      ).forEach((jaHeading) => {
        const enHeading = jaHeading.previousElementSibling as HTMLElement | null;
        const enBtn = enHeading?.querySelector<HTMLElement>('.anchor-copy-btn');
        if (!enBtn) return;
        jaHeading.addEventListener('mouseenter', () => {
          enBtn.style.opacity = '1';
          enBtn.style.pointerEvents = 'auto';
        });
        jaHeading.addEventListener('mouseleave', () => {
          enBtn.style.opacity = '';
          enBtn.style.pointerEvents = '';
        });
      });
    })();
  </script>
</body>
</html>
